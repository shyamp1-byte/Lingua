# Copy this file to .env and fill in your keys

# Required — Deepgram (speech-to-text): https://console.deepgram.com
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# Optional — DeepL (translation): https://www.deepl.com/pro-api
# Without this, captions will not be translated
DEEPL_API_KEY=your_deepl_api_key_here

# Optional — OpenAI (session summaries): https://platform.openai.com
# Without this, AI title/summary will not be generated after sessions
OPENAI_API_KEY=your_openai_api_key_here
