{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Lingua",
  "version": "0.1.0",
  "identifier": "com.lingua.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Lingua",
        "width": 440,
        "height": 660,
        "resizable": false,
        "center": true
      },
      {
        "label": "overlay",
        "title": "",
        "transparent": true,
        "decorations": false,
        "shadow": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "width": 960,
        "height": 160,
        "x": 80,
        "y": 880,
        "visible": false,
        "focus": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "macOS": {
      "entitlements": "./Entitlements.plist",
      "infoPlist": "./InfoExtra.plist"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
